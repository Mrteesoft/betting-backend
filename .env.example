NODE_ENV=development
PORT=3000
API_KEYS=local-dev-key
RATE_LIMIT_PER_MINUTE=120
CONTEXT_CACHE_TTL_MS=60000
IDEMPOTENCY_TTL_SEC=600
CLUSTER_ENABLED=false
ANCHOR_PARTNER_API_KEY=
OTS_EXCLUSIVE_TO_ANCHOR=false

# Required for the live One For All board
HIGHLIGHTLY_FOOTBALL_KEY=replace-with-your-highlightly-key
HIGHLIGHTLY_FOOTBALL_BASE_URL=https://soccer.highlightly.net
HIGHLIGHTLY_FOOTBALL_TIMEZONE=Africa/Lagos
HIGHLIGHTLY_FOOTBALL_CACHE_TTL_MS=180000
HIGHLIGHTLY_FOOTBALL_FIXTURE_LIMIT=18
HIGHLIGHTLY_FOOTBALL_LOOKAHEAD_DAYS=1
HIGHLIGHTLY_FOOTBALL_BOOKMAKER_ID=
HIGHLIGHTLY_FOOTBALL_ODDS_ENABLED=false
HIGHLIGHTLY_FOOTBALL_TIMEOUT_MS=15000
